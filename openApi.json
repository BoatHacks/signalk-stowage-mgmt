{
  "openapi": "3.0.3",
  "info": {
    "title": "Stowage Management",
    "description": "Inventory manager for Signal K Server: organize items into containers and storage spaces, track actual vs. target quantities, attach photos and markdown notes, and map storage spaces to areas on an SVG floorplan.",
    "version": "0.5.3",
    "license": { "name": "Apache-2.0", "url": "https://www.apache.org/licenses/LICENSE-2.0" }
  },
  "servers": [
    { "url": "/plugins/signalk-stowage-mgmt" }
  ],
  "tags": [
    { "name": "Locations", "description": "Storage spaces and containers (a shared hierarchy)" },
    { "name": "Items", "description": "Inventory items" },
    { "name": "Categories", "description": "Tags that can be attached to items" },
    { "name": "Floorplans", "description": "Uploaded SVG floorplans and their area-to-storage-space mappings" }
  ],
  "paths": {
    "/locations": {
      "get": {
        "tags": ["Locations"],
        "summary": "List all locations",
        "responses": {
          "200": {
            "description": "All storage spaces and containers",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Location" } } } }
          }
        }
      },
      "post": {
        "tags": ["Locations"],
        "summary": "Create a storage space or container",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "type"],
                "properties": {
                  "name": { "type": "string" },
                  "type": { "type": "string", "enum": ["storage_space", "container"] },
                  "parent_id": { "type": "string", "nullable": true, "description": "Parent location id. Required for containers to nest inside something (omit for a top-level storage space)." }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Location" } } } },
          "400": { "description": "Missing/invalid name or type, or parent_id does not exist", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/locations/{id}": {
      "patch": {
        "tags": ["Locations"],
        "summary": "Rename a location",
        "parameters": [{ "$ref": "#/components/parameters/LocationId" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "name": { "type": "string" } } } } }
        },
        "responses": {
          "200": { "description": "Updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Location" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "tags": ["Locations"],
        "summary": "Delete a location",
        "description": "Only succeeds if the location has no child locations and no items directly in it.",
        "parameters": [{ "$ref": "#/components/parameters/LocationId" }],
        "responses": {
          "204": { "description": "Deleted" },
          "400": { "description": "Location is not empty", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/locations/{id}/move": {
      "patch": {
        "tags": ["Locations"],
        "summary": "Re-parent a location",
        "description": "Moves a container under another container or storage space, or makes a location top-level by omitting/nulling parent_id. Rejects moves that would create a cycle.",
        "parameters": [{ "$ref": "#/components/parameters/LocationId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "properties": { "parent_id": { "type": "string", "nullable": true } } }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Location" } } } },
          "400": { "description": "parent_id does not exist, is the location itself, or would create a cycle", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/locations/{id}/svg-mapping": {
      "patch": {
        "tags": ["Locations"],
        "summary": "Assign or clear a storage space's floorplan area",
        "description": "Only valid on locations of type storage_space. Pass null/omit both fields to clear the mapping.",
        "parameters": [{ "$ref": "#/components/parameters/LocationId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "floorplan_id": { "type": "string", "nullable": true },
                  "svg_element_id": { "type": "string", "nullable": true, "description": "The id attribute of the SVG shape representing this storage space." }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Location" } } } },
          "400": { "description": "Not a storage_space, or floorplan_id does not exist", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/items": {
      "get": {
        "tags": ["Items"],
        "summary": "List all items",
        "responses": {
          "200": { "description": "All items, each with a categories array", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Item" } } } } }
        }
      },
      "post": {
        "tags": ["Items"],
        "summary": "Create an item",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "actual_quantity": { "type": "integer", "default": 1 },
                  "target_quantity": { "type": "integer", "nullable": true },
                  "notes": { "type": "string", "nullable": true },
                  "location_id": { "type": "string", "nullable": true },
                  "category_ids": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Item" } } } },
          "400": { "description": "Missing name, or location_id/category_id does not exist", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/items/{id}": {
      "patch": {
        "tags": ["Items"],
        "summary": "Update item properties",
        "description": "Partial update. target_quantity and notes support an explicit null to clear them, distinct from omitting the key (which leaves the current value unchanged).",
        "parameters": [{ "$ref": "#/components/parameters/ItemId" }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "actual_quantity": { "type": "integer" },
                  "target_quantity": { "type": "integer", "nullable": true },
                  "notes": { "type": "string", "nullable": true }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Item" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "tags": ["Items"],
        "summary": "Delete an item",
        "parameters": [{ "$ref": "#/components/parameters/ItemId" }],
        "responses": {
          "204": { "description": "Deleted" },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/items/{id}/thumbnail": {
      "patch": {
        "tags": ["Items"],
        "summary": "Set or clear an item's photo",
        "parameters": [{ "$ref": "#/components/parameters/ItemId" }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "thumbnail": { "type": "string", "nullable": true, "description": "A data: URI (e.g. a JPEG data URI), or null/omitted to remove the thumbnail." }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Item" } } } },
          "400": { "description": "thumbnail was not a string", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/items/{id}/move": {
      "patch": {
        "tags": ["Items"],
        "summary": "Move an item to a different location",
        "parameters": [{ "$ref": "#/components/parameters/ItemId" }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "location_id": { "type": "string", "nullable": true, "description": "Omit/null to unassign the item (no location)." } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Item" } } } },
          "400": { "description": "location_id does not exist", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/items/{id}/categories": {
      "post": {
        "tags": ["Items"],
        "summary": "Add a category to an item",
        "parameters": [{ "$ref": "#/components/parameters/ItemId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "required": ["category_id"], "properties": { "category_id": { "type": "string" } } }
            }
          }
        },
        "responses": {
          "201": { "description": "Category added (or already present)", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Item" } } } },
          "400": { "description": "category_id does not exist", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Item not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/items/{id}/categories/{categoryId}": {
      "delete": {
        "tags": ["Items"],
        "summary": "Remove a category from an item",
        "parameters": [
          { "$ref": "#/components/parameters/ItemId" },
          { "name": "categoryId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Category removed", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Item" } } } },
          "404": { "description": "Item not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/items/{id}/locate": {
      "get": {
        "tags": ["Items"],
        "summary": "Find the mapped storage space for an item",
        "description": "Walks up the item's location chain until it finds a storage space mapped to a floorplan area, so a client knows which SVG element to highlight. Works no matter how deeply the item is nested in containers.",
        "parameters": [{ "$ref": "#/components/parameters/ItemId" }],
        "responses": {
          "200": {
            "description": "A mapped storage space was found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "item_id": { "type": "string" },
                    "path": { "type": "array", "items": { "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "type": { "type": "string" } } } },
                    "floorplan_id": { "type": "string" },
                    "svg_element_id": { "type": "string" },
                    "storage_space": { "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" } } }
                  }
                }
              }
            }
          },
          "404": { "description": "Item has no location, or no mapped storage space was found in its location chain", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/categories": {
      "get": {
        "tags": ["Categories"],
        "summary": "List all categories",
        "responses": {
          "200": { "description": "All categories", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Category" } } } } }
        }
      },
      "post": {
        "tags": ["Categories"],
        "summary": "Create a category",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "required": ["name"], "properties": { "name": { "type": "string" } } } } }
        },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Category" } } } },
          "400": { "description": "Missing name", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "409": { "description": "A category with this name already exists", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/categories/{id}": {
      "patch": {
        "tags": ["Categories"],
        "summary": "Rename a category",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "required": ["name"], "properties": { "name": { "type": "string" } } } } }
        },
        "responses": {
          "200": { "description": "Updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Category" } } } },
          "400": { "description": "Missing name", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "409": { "description": "A category with this name already exists", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "tags": ["Categories"],
        "summary": "Delete a category",
        "description": "Also removes this category from every item that had it.",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "204": { "description": "Deleted" },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/floorplans": {
      "get": {
        "tags": ["Floorplans"],
        "summary": "List floorplans",
        "description": "Returns id/name/uploaded_at only (not the SVG content); ordered newest first.",
        "responses": {
          "200": { "description": "All floorplans", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/FloorplanSummary" } } } } }
        }
      },
      "post": {
        "tags": ["Floorplans"],
        "summary": "Upload a floorplan",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "svg_content"],
                "properties": {
                  "name": { "type": "string" },
                  "svg_content": { "type": "string", "description": "Raw SVG markup as text." }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FloorplanSummary" } } } },
          "400": { "description": "Missing name/svg_content, or svg_content is not valid SVG", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/floorplans/{id}": {
      "get": {
        "tags": ["Floorplans"],
        "summary": "Get one floorplan including its SVG content",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "The floorplan", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Floorplan" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "tags": ["Floorplans"],
        "summary": "Delete a floorplan",
        "description": "Only succeeds if no storage space is still mapped to it.",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "204": { "description": "Deleted" },
          "400": { "description": "Floorplan is still mapped to storage spaces", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "LocationId": { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
      "ItemId": { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": { "error": { "type": "string" } }
      },
      "Location": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["storage_space", "container"] },
          "parent_id": { "type": "string", "nullable": true },
          "floorplan_id": { "type": "string", "nullable": true },
          "svg_element_id": { "type": "string", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "CategoryRef": {
        "type": "object",
        "properties": { "id": { "type": "string" }, "name": { "type": "string" } }
      },
      "Item": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "actual_quantity": { "type": "integer" },
          "target_quantity": { "type": "integer", "nullable": true },
          "notes": { "type": "string", "nullable": true },
          "location_id": { "type": "string", "nullable": true },
          "thumbnail": { "type": "string", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" },
          "categories": { "type": "array", "items": { "$ref": "#/components/schemas/CategoryRef" } }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "FloorplanSummary": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "uploaded_at": { "type": "string", "format": "date-time" }
        }
      },
      "Floorplan": {
        "allOf": [
          { "$ref": "#/components/schemas/FloorplanSummary" },
          { "type": "object", "properties": { "svg_content": { "type": "string" } } }
        ]
      }
    }
  }
}
