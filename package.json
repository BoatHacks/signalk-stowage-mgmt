{
  "name": "signalk-stowage-mgmt",
  "version": "0.8.11",
  "description": "Organize items into containers and storage spaces, locate them, track item consumption, and lots more.",
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-utility"
  ],
  "signalk-plugin-enabled-by-default": false,
  "signalk": {
    "displayName": "Stowage Management",
    "appIcon": "./assets/icons/icon-512.png",
    "recommends": [
      "signalk-maintenance-tracker"
    ],
    "screenshots": [
      "./docs/screenshots/inventory.png",
      "./docs/screenshots/floorplan.png",
      "./docs/screenshots/overview.png",
      "./docs/screenshots/categories.png",
      "./docs/screenshots/stock-alerts.png",
      "./docs/screenshots/store-log.png"
    ]
  },
  "main": "plugin/index.js",
  "scripts": {
    "test": "node --test"
  },
  "author": "Tobias Rosenstock",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BoatHacks/signalk-stowage-mgmt.git"
  },
  "homepage": "https://github.com/BoatHacks/signalk-stowage-mgmt#readme",
  "bugs": {
    "url": "https://github.com/BoatHacks/signalk-stowage-mgmt/issues"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "express": "^5.2.1"
  }
}
